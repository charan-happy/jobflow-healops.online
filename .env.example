# Database
DATABASE_URL=postgresql+asyncpg://jobflow:jobflow123@localhost:5432/jobflow
DATABASE_URL_SYNC=postgresql://jobflow:jobflow123@localhost:5432/jobflow

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM - Groq Free Tier
GROQ_API_KEY=your_groq_api_key_here

# JWT Auth
JWT_SECRET=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# File Storage
UPLOAD_DIR=./uploads/resumes

# Frontend
FRONTEND_URL=http://localhost:3000

# Environment
ENV=development
