          },
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] }
      },
      "targets": [
        {
          "expr": "sum(increase(jobflow_http_requests_total{status=~\"2..\"}[24h]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "expr": "sum(increase(jobflow_http_requests_total{status=~\"4..\"}[24h]))",
          "legendFormat": "4xx",
          "refId": "B"
        },
        {
          "expr": "sum(increase(jobflow_http_requests_total{status=~\"5..\"}[24h]))",
          "legendFormat": "5xx",
          "refId": "C"
        }
      ]
    }
