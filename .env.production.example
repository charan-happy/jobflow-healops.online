# ===========================================
# Production Environment Variables
# Copy to .env.production and fill in values
# ===========================================

# Domain (no https://, no trailing slash)
DOMAIN=jobflow.healops.online

# Database
POSTGRES_USER=jobflow
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=jobflow

# Redis
REDIS_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# LLM - Groq Free Tier (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here

# JWT Auth (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Email Notifications (Gmail: use App Password, not regular password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Frontend URL (used in CORS, email links)
FRONTEND_URL=https://jobflow.healops.online

# File Storage
UPLOAD_DIR=./uploads/resumes

# Grafana (grafana.jobflow.healops.online)
GRAFANA_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Environment
ENV=production
